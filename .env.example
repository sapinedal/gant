# Variables para docker-compose.yml (copia este archivo a ".env" y complétalo,
# o defínelas como variables de entorno en Dokploy).

# Genera con: php artisan key:generate --show  (dentro del contenedor backend, o localmente con PHP)
APP_KEY=

APP_NAME="Trazalo Gantt"
APP_URL=https://tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

DB_DATABASE=trazalo-gantt
DB_USERNAME=postgres
DB_PASSWORD=

# Puerto público donde quedará expuesto el frontend (que internamente sirve /api también)
HTTP_PORT=8080

# Correo: por defecto queda en el log del contenedor si dejas MAIL_MAILER=log.
MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_EHLO_DOMAIN=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Trazalo Gantt"
